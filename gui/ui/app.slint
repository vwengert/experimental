import { Button, ComboBox, ScrollView, VerticalBox, HorizontalBox, LineEdit } from "std-widgets.slint";
import { KeyValuePair, LineItem, ActionType, Action } from "structs.slint";

export component AppWindow inherits Window {
    title: "Schema Elements Editor";
    min-width: 600px;
    min-height: 400px;
    preferred-width: 800px;
    preferred-height: 600px;

    in property <[string]> schema-names;
    in-out property <[LineItem]> lines;
    in property <[string]> list-names;
    in-out property <int> active-list-index: 0;

    // File dialog state
    private property <bool> file-dialog-is-save: true;
    private property <string> file-dialog-path: "lists.json";

    callback dispatch(Action);

    // File path popup
    file-dialog := PopupWindow {
        x: (root.width - 320px) / 2;
        y: (root.height - 160px) / 2;
        width: 320px;
        height: 160px;
        close-policy: PopupClosePolicy.no-auto-close;

        Rectangle {
            background: #f5f5f5;
            border-width: 1px;
            border-color: #999999;
            border-radius: 6px;

            VerticalBox {
                padding: 12px;
                spacing: 8px;

                Text {
                    text: root.file-dialog-is-save ? "Save list to file:" : "Load list from file:";
                    font-weight: 600;
                }

                file-path-input := LineEdit {
                    text: root.file-dialog-path;
                    placeholder-text: "Enter file path…";
                }

                HorizontalBox {
                    alignment: end;
                    spacing: 8px;

                    Button {
                        text: "Cancel";
                        clicked => { file-dialog.close(); }
                    }

                    Button {
                        text: root.file-dialog-is-save ? "Save" : "Load";
                        clicked => {
                            root.file-dialog-path = file-path-input.text;
                            root.dispatch({
                                action-type: root.file-dialog-is-save
                                    ? ActionType.save-list
                                    : ActionType.load-list,
                                schema-name: "",
                                line-index: 0,
                                pair-index: 0,
                                new-value: file-path-input.text,
                            });
                            file-dialog.close();
                        }
                    }
                }
            }
        }
    }

    // File menu
    MenuBar {
        Menu {
            title: "File";

            MenuItem {
                title: "Save";
                activated => {
                    root.file-dialog-is-save = true;
                    file-dialog.show();
                }
            }

            MenuItem {
                title: "Load";
                activated => {
                    root.file-dialog-is-save = false;
                    file-dialog.show();
                }
            }
        }
    }

    VerticalBox {
        // Tab bar wrapped in a horizontal ScrollView so it scrolls when tabs overflow
        ScrollView {
            height: 42px;
            vertical-scrollbar-policy: ScrollBarPolicy.always-off;

            HorizontalLayout {
                padding: 4px;
                spacing: 4px;
                alignment: start;

                for tab-name[ti] in root.list-names: Rectangle {
                    width: 90px;
                    height: 30px;
                    background: ti == root.active-list-index ? #4a90d9 : #d0d0d0;
                    border-radius: 4px;

                    Text {
                        text: tab-name;
                        color: ti == root.active-list-index ? #ffffff : #333333;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                        font-weight: ti == root.active-list-index ? 700 : 400;
                    }

                    TouchArea {
                        clicked => {
                            root.active-list-index = ti;
                            root.dispatch({
                                action-type: ActionType.switch-list,
                                schema-name: "",
                                line-index: ti,
                                pair-index: 0,
                                new-value: "",
                            });
                        }
                    }
                }

                Button {
                    text: "+ Add List";
                    clicked => {
                        root.dispatch({
                            action-type: ActionType.add-list,
                            schema-name: "",
                            line-index: 0,
                            pair-index: 0,
                            new-value: "",
                        });
                    }
                }
            }
        }

        // Delete-list toolbar (only visible when a non-first tab is active)
        if root.active-list-index > 0: HorizontalBox {
            alignment: start;
            padding: 4px;
            spacing: 8px;

            Button {
                text: "Delete List";
                clicked => {
                    root.dispatch({
                        action-type: ActionType.remove-list,
                        schema-name: "",
                        line-index: root.active-list-index,
                        pair-index: 0,
                        new-value: "",
                    });
                }
            }
        }

        // Add-line toolbar
        HorizontalBox {
            alignment: start;
            padding: 8px;
            spacing: 8px;

            schema-selector := ComboBox {
                model: root.schema-names;
            }

            Button {
                text: "Add Line";
                clicked => {
                    root.dispatch({
                        action-type: ActionType.add-line,
                        schema-name: schema-selector.current-value,
                        line-index: 0,
                        pair-index: 0,
                        new-value: "",
                    });
                }
            }
        }

        ScrollView {
            VerticalLayout {
                spacing: 8px;
                padding: 8px;
                alignment: start;

                for line[i] in root.lines: Rectangle {
                    border-width: 1px;
                    border-color: #cccccc;
                    border-radius: 4px;

                    VerticalLayout {
                        spacing: 4px;
                        padding: 8px;

                        // Line header: type selector + delete button
                        HorizontalLayout {
                            spacing: 8px;
                            alignment: start;

                            ComboBox {
                                model: root.schema-names;
                                current-value: line.title;
                                selected(value) => {
                                    root.dispatch({
                                        action-type: ActionType.line-type-changed,
                                        schema-name: value,
                                        line-index: i,
                                        pair-index: 0,
                                        new-value: "",
                                    });
                                }
                            }

                            Button {
                                text: "✕";
                                clicked => {
                                    root.dispatch({
                                        action-type: ActionType.remove-line,
                                        schema-name: "",
                                        line-index: i,
                                        pair-index: 0,
                                        new-value: "",
                                    });
                                }
                            }
                        }

                        for pair[j] in line.pairs: HorizontalBox {
                            alignment: start;
                            spacing: 8px;

                            Text {
                                text: pair.key + ":";
                                min-width: 150px;
                                vertical-alignment: center;
                            }

                            LineEdit {
                                text: pair.value;
                                min-width: 200px;
                                edited(new-value) => {
                                    root.dispatch({
                                        action-type: ActionType.value-changed,
                                        schema-name: "",
                                        line-index: i,
                                        pair-index: j,
                                        new-value: new-value,
                                    });
                                }
                            }

                            if pair.unit-options.length > 0: ComboBox {
                                model: pair.unit-options;
                                current-value: pair.unit;
                                selected(new-unit) => {
                                    root.dispatch({
                                        action-type: ActionType.unit-changed,
                                        schema-name: "",
                                        line-index: i,
                                        pair-index: j,
                                        new-value: new-unit,
                                    });
                                }
                            }

                            if pair.unit-options.length == 0 && pair.unit != "": Text {
                                text: pair.unit;
                                vertical-alignment: center;
                            }
                        }
                    }
                }
            }
        }
    }
}
