import { Button, ComboBox, ScrollView, VerticalBox, HorizontalBox, LineEdit } from "std-widgets.slint";

struct KeyValuePair {
    key: string,
    value: string,
}

struct LineItem {
    title: string,
    pairs: [KeyValuePair],
}

enum ActionType {
    add-line,
    value-changed,
    line-type-changed,
    save,
    load,
}

struct Action {
    action-type: ActionType,
    schema-name: string,
    line-index: int,
    pair-index: int,
    new-value: string,
}

export component AppWindow inherits Window {
    title: "Schema Elements Editor";
    min-width: 600px;
    min-height: 400px;
    preferred-width: 800px;
    preferred-height: 600px;

    in property <[string]> schema-names;
    in-out property <[LineItem]> lines;

    callback dispatch(Action);

    MenuBar {
        Menu {
            title: "File";
            MenuItem {
                title: "Load";
                activated => {
                    root.dispatch({
                        action-type: ActionType.load,
                        schema-name: "",
                        line-index: 0,
                        pair-index: 0,
                        new-value: "",
                    });
                }
            }
            MenuItem {
                title: "Save";
                activated => {
                    root.dispatch({
                        action-type: ActionType.save,
                        schema-name: "",
                        line-index: 0,
                        pair-index: 0,
                        new-value: "",
                    });
                }
            }
        }
    }

    VerticalBox {
        HorizontalBox {
            alignment: start;
            padding: 8px;
            spacing: 8px;

            schema-selector := ComboBox {
                model: root.schema-names;
            }

            Button {
                text: "Add Line";
                clicked => {
                    root.dispatch({
                        action-type: ActionType.add-line,
                        schema-name: schema-selector.current-value,
                        line-index: 0,
                        pair-index: 0,
                        new-value: "",
                    });
                }
            }
        }

        ScrollView {
            VerticalLayout {
                spacing: 8px;
                padding: 8px;
                alignment: start;

                for line[i] in root.lines: Rectangle {
                    border-width: 1px;
                    border-color: #cccccc;
                    border-radius: 4px;

                    VerticalLayout {
                        spacing: 4px;
                        padding: 8px;

                        ComboBox {
                            model: root.schema-names;
                            current-value: line.title;
                            selected(value) => {
                                root.dispatch({
                                    action-type: ActionType.line-type-changed,
                                    schema-name: value,
                                    line-index: i,
                                    pair-index: 0,
                                    new-value: "",
                                });
                            }
                        }

                        for pair[j] in line.pairs: HorizontalBox {
                            alignment: start;
                            spacing: 8px;

                            Text {
                                text: pair.key + ":";
                                min-width: 150px;
                                vertical-alignment: center;
                            }

                            LineEdit {
                                text: pair.value;
                                min-width: 300px;
                                edited(new-value) => {
                                    root.dispatch({
                                        action-type: ActionType.value-changed,
                                        schema-name: "",
                                        line-index: i,
                                        pair-index: j,
                                        new-value: new-value,
                                    });
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}
