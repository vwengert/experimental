import { Button, ComboBox, ScrollView, VerticalBox, HorizontalBox } from "std-widgets.slint";
import { LineItem, ActionType, Action } from "structs.slint";
import { FileDialog } from "file-dialog.slint";
import { LineCard } from "line-card.slint";

export component AppWindow inherits Window {
    title: "Schema Elements Editor";
    min-width: 600px;
    min-height: 400px;
    preferred-width: 800px;
    preferred-height: 600px;

    in property <[string]> schema-names;
    in-out property <[LineItem]> lines;
    in property <[string]> list-names;
    in-out property <int> active-list-index: 0;
    in-out property <bool> is-dirty: false;

    // File dialog state
    private property <bool> file-dialog-is-save: true;

    callback dispatch(Action);

    // File path popup
    file-dialog := FileDialog {
        x: (root.width - 320px) / 2;
        y: (root.height - 160px) / 2;
        is-save: root.file-dialog-is-save;
        confirmed(path) => {
            root.dispatch({
                action-type: root.file-dialog-is-save
                    ? ActionType.save-list
                    : ActionType.load-list,
                schema-name: "",
                line-index: 0,
                pair-index: 0,
                new-value: path,
            });
        }
    }

    // Exit confirmation popup
    confirm-exit-dialog := PopupWindow {
        x: (root.width - 320px) / 2;
        y: (root.height - 140px) / 2;
        width: 320px;
        height: 140px;
        close-policy: PopupClosePolicy.no-auto-close;

        Rectangle {
            background: #f5f5f5;
            border-width: 1px;
            border-color: #999999;
            border-radius: 6px;

            VerticalBox {
                padding: 12px;
                spacing: 8px;

                Text {
                    text: "You have unsaved changes. Exit anyway?";
                    wrap: word-wrap;
                }

                HorizontalBox {
                    alignment: end;
                    spacing: 8px;

                    Button {
                        text: "Cancel";
                        clicked => { confirm-exit-dialog.close(); }
                    }

                    Button {
                        text: "Exit Anyway";
                        clicked => {
                            confirm-exit-dialog.close();
                            root.dispatch({
                                action-type: ActionType.exit,
                                schema-name: "",
                                line-index: 0,
                                pair-index: 0,
                                new-value: "",
                            });
                        }
                    }
                }
            }
        }
    }

    // File menu
    MenuBar {
        Menu {
            title: "File";

            MenuItem {
                title: "Save";
                activated => {
                    root.file-dialog-is-save = true;
                    file-dialog.show();
                }
            }

            MenuItem {
                title: "Load";
                activated => {
                    root.file-dialog-is-save = false;
                    file-dialog.show();
                }
            }

            MenuItem {
                title: "Exit";
                activated => {
                    if root.is-dirty {
                        confirm-exit-dialog.show();
                    } else {
                        root.dispatch({
                            action-type: ActionType.exit,
                            schema-name: "",
                            line-index: 0,
                            pair-index: 0,
                            new-value: "",
                        });
                    }
                }
            }
        }
    }

    VerticalBox {
        // Tab bar wrapped in a horizontal ScrollView so it scrolls when tabs overflow
        ScrollView {
            height: 42px;
            vertical-scrollbar-policy: ScrollBarPolicy.always-off;

            HorizontalLayout {
                padding: 4px;
                spacing: 4px;
                alignment: start;

                for tab-name[ti] in root.list-names: Rectangle {
                    width: 90px;
                    height: 30px;
                    background: ti == root.active-list-index ? #4a90d9 : #d0d0d0;
                    border-radius: 4px;

                    Text {
                        text: tab-name;
                        color: ti == root.active-list-index ? #ffffff : #333333;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                        font-weight: ti == root.active-list-index ? 700 : 400;
                    }

                    TouchArea {
                        clicked => {
                            root.active-list-index = ti;
                            root.dispatch({
                                action-type: ActionType.switch-list,
                                schema-name: "",
                                line-index: ti,
                                pair-index: 0,
                                new-value: "",
                            });
                        }
                    }
                }

                Button {
                    text: "+ Add List";
                    clicked => {
                        root.dispatch({
                            action-type: ActionType.add-list,
                            schema-name: "",
                            line-index: 0,
                            pair-index: 0,
                            new-value: "",
                        });
                    }
                }
            }
        }

        // Delete-list toolbar (only visible when a non-first tab is active)
        if root.active-list-index > 0: HorizontalBox {
            alignment: start;
            padding: 4px;
            spacing: 8px;

            Button {
                text: "Delete List";
                clicked => {
                    root.dispatch({
                        action-type: ActionType.remove-list,
                        schema-name: "",
                        line-index: root.active-list-index,
                        pair-index: 0,
                        new-value: "",
                    });
                }
            }
        }

        // Add-line toolbar
        HorizontalBox {
            alignment: start;
            padding: 8px;
            spacing: 8px;

            schema-selector := ComboBox {
                model: root.schema-names;
            }

            Button {
                text: "Add Line";
                clicked => {
                    root.dispatch({
                        action-type: ActionType.add-line,
                        schema-name: schema-selector.current-value,
                        line-index: 0,
                        pair-index: 0,
                        new-value: "",
                    });
                }
            }
        }

        ScrollView {
            VerticalLayout {
                spacing: 8px;
                padding: 8px;
                alignment: start;

                for line[i] in root.lines: LineCard {
                    line: line;
                    schema-names: root.schema-names;
                    line-index: i;
                    dispatch(action) => { root.dispatch(action); }
                }
            }
        }
    }
}
