
export struct FileEntry {
    name: string,
    is-dir: bool,
}

export struct KeyData {
    key: string,
    value: string,
    unit: string,
    unit-options: [string],
    is-valid: bool,
}

export struct LineItem {
    title: string,
    data: [KeyData],
}

export enum ActionType {
    add-line,
    value-changed,
    unit-changed,
    line-type-changed,
    remove-line,
    switch-list,
    add-list,
    remove-list,
    save-list,
    load-list,
    navigate-dir,
    exit,
    validate-before-save,
}

export struct Action {
    action-type: ActionType,
    schema-name: string,
    line-index: int,
    pair-index: int,
    new-value: string,
}
