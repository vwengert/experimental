import { Button, ComboBox, HorizontalBox, LineEdit, GroupBox, GridBox } from "std-widgets.slint";
import { KeyData, LineItem, LineState, ActionType, Action } from "structs.slint";

// One row in a LineCard: shows a key-value pair with validation feedback.
component LineRow {
    in property <KeyData> key-data;
    in property <string> line-title;
    in property <int> key-data-index;
    in property <int> line-index;
    in property <int> validate-epoch: 0;
    in property <int> focus-key-data: -1;
    in property <int> focus-line: -1;
    in property <int> focused-key-data-index: -1;
    in property <int> focus-check-transfer-epoch: 0;
    in property <int> focus-check-transfer-target-key-data: -1;

    callback dispatch(Action);
    callback focus-changed(int, bool);
    callback request-focus-check-transfer();

    // When the epoch increments (a new validate-all ran), focus this field if requested.
    changed validate-epoch => {
        if (validate-epoch > 0 && focus-line == line-index && focus-key-data == key-data-index) {
            le.focus();
        }
    }

    changed focus-check-transfer-epoch => {
        if (focus-check-transfer-epoch > 0 && focus-check-transfer-target-key-data == key-data-index) {
            focus-check-timer.stop();
            focus-check-timer.start();
        }
    }

    // Auto-focus on first field only on init
    init => {
        if (key-data-index == 0) {
            init-focus-timer.start();
        }
    }

    init-focus-timer := Timer {
        interval: 10ms;
        running: false;
        triggered => {
            le.focus();
            self.stop();
        }
    }

    HorizontalBox {
        alignment: start;
        spacing: 8px;

        Text {
            text: key-data.key + ":";
            min-width: 150px;
            vertical-alignment: center;
        }

        le := LineEdit {
            text: key-data.value;
            min-width: 200px;
            changed has-focus => {
                root.focus-changed(root.key-data-index, le.has-focus);
            }
            edited(new-value) => {
                root.dispatch({
                    action-type: ActionType.value-changed,
                    schema-name: "",
                    line-index: root.line-index,
                    key-data-index: root.key-data-index,
                    new-value: new-value,
                });
                focus-check-timer.stop();
                focus-check-timer.start();
            }
            key-pressed(event) => {
                if (event.text == Key.Tab) {
                    root.dispatch({
                        action-type: event.modifiers.shift ? ActionType.tab-prev-field : ActionType.tab-next-field,
                        schema-name: "",
                        line-index: root.line-index,
                        key-data-index: root.key-data-index,
                        new-value: "",
                    });
                    accept;
                }
                reject;
            }
        }

        focus-check-timer := Timer {
            interval: 1s;
            running: false;
            triggered => {
                if (le.has-focus) {
                    self.start();
                } else {
                    if (focused-key-data-index >= 0 && focused-key-data-index != key-data-index) {
                        root.request-focus-check-transfer();
                    } else {
                        root.dispatch({
                            action-type: ActionType.debounced-field-check,
                            schema-name: "",
                            line-index: root.line-index,
                            key-data-index: root.key-data-index,
                            new-value: "",
                        });
                    }
                    self.stop();
                }
            }
        }



        if key-data.unit-options.length > 0: ComboBox {
            model: key-data.unit-options;
            current-value: key-data.unit;
            selected(new-unit) => {
                root.dispatch({
                    action-type: ActionType.unit-changed,
                    schema-name: "",
                    line-index: root.line-index,
                    key-data-index: root.key-data-index,
                    new-value: new-unit,
                });
            }
        }

        if key-data.unit-options.length == 0 && key-data.unit != "": Text {
            text: key-data.unit;
            vertical-alignment: center;
        }
    }
}

export component LineCard inherits GroupBox {
    in property <LineItem> line;
    in property <[string]> schema-names;
    in property <[string]> init-schema-names;
    in property <int> line-index;
    // Focus-first-invalid support
    in property <int> validate-epoch: 0;
    in property <int> focus-line: -1;
    in property <int> focus-key-data: -1;
    in-out property <int> focused-key-data-index: -1;
    in-out property <int> focus-check-transfer-epoch: 0;
    in-out property <int> focus-check-transfer-target-key-data: -1;

    callback dispatch(Action);

    public function any-row-has-focus() -> bool {
        return focused-key-data-index >= 0;
    }

    title: "Line " + (root.line-index + 1);
    Rectangle {
        border-width: 1px;
        border-color: #cccccc;
        border-radius: 4px;

        VerticalLayout {
            spacing: 4px;
            padding: 8px;

        // Line header: type selector + delete button + validation indicator
             HorizontalLayout {
                 spacing: 8px;
                 alignment: space-between;


                       HorizontalLayout {
                           spacing: 8px;
                           alignment: start;

                           ComboBox {
                               model: root.line-index == 0 ? root.init-schema-names : root.schema-names;
                               current-value: root.line.title;
                               selected(value) => {
                                   root.dispatch({
                                       action-type: ActionType.line-type-changed,
                                       schema-name: value,
                                       line-index: root.line-index,
                                       key-data-index: 0,
                                       new-value: "",
                                   });
                               }
                           }

                           if root.line-index != 0: Button {
                               text: "x";
                               clicked => {
                                   root.dispatch({
                                       action-type: ActionType.remove-line,
                                       schema-name: "",
                                       line-index: root.line-index,
                                       key-data-index: 0,
                                       new-value: "",
                                   });
                               }
                           }
                       }

                       HorizontalLayout {
                           spacing: 8px;
                           alignment: end;

                           if root.line.state == LineState.invalid: Text {
                               text: "invalid";
                               color: red;
                               vertical-alignment: center;
                           }
                           if root.line.state == LineState.valid: Text {
                               text: "valid";
                               color: #ffb81c;
                               vertical-alignment: center;
                           }
                           if root.line.state == LineState.running: Text {
                               text: "running";
                               color: #1f6feb;
                               vertical-alignment: center;
                           }
                           if root.line.state == LineState.done: Text {
                               text: "done";
                               color: #2da44e;
                               vertical-alignment: center;
                           }
                       }
                   }

             for key-data[j] in root.line.data: LineRow {
                key-data: key-data;
                line-title: root.line.title;
                key-data-index: j;
                line-index: root.line-index;
                validate-epoch: root.validate-epoch;
                focus-line: root.focus-line;
                focus-key-data: root.focus-key-data;
                focused-key-data-index: root.focused-key-data-index;
                focus-check-transfer-epoch: root.focus-check-transfer-epoch;
                focus-check-transfer-target-key-data: root.focus-check-transfer-target-key-data;
                focus-changed(idx, has-focus) => {
                    if (has-focus) {
                        root.focused-key-data-index = idx;
                    } else if (root.focused-key-data-index == idx) {
                        root.focused-key-data-index = -1;
                    }
                }
                request-focus-check-transfer() => {
                    if (root.any-row-has-focus()) {
                        root.focus-check-transfer-target-key-data = root.focused-key-data-index;
                        root.focus-check-transfer-epoch += 1;
                    }
                }
                dispatch(action) => {
                    root.dispatch(action);
                }
            }
        }
    }
}
