import { Button, LineEdit, VerticalBox, HorizontalBox, ScrollView } from "std-widgets.slint";
import { FileEntry } from "structs.slint";

component IconButton inherits Rectangle {
    in property <image> icon;
    in property <string> label;
    callback clicked();

    border-width: 1px;
    border-color: #999;
    border-radius: 4px;
    background: ta.pressed ? #dcdcdc : (ta.has-hover ? #efefef : #f7f7f7);

    content := VerticalLayout {
        spacing: 2px;
        alignment: center;

        HorizontalLayout {
            spacing: 2px;
            alignment: center;

            Image {
                source: root.icon;
                width: 16px;
                height: 16px;
            }

            Text {
                text: root.label;
            }
        }
    }

    ta := TouchArea {
        clicked => { root.clicked(); }
    }
}
export component FileDialog inherits PopupWindow {
    width: 600px;
    height: 460px;
    close-policy: PopupClosePolicy.no-auto-close;

    in property <bool> is-save: true;
    in property <string> current-dir;
    in property <[FileEntry]> entries;
    in-out property <string> file-name;

    callback navigate(string);
    callback confirmed(string);

    Rectangle {
        background: #f5f5f5;
        border-width: 1px;
        border-color: #999999;
        border-radius: 6px;

        VerticalBox {
            padding: 12px;
            spacing: 8px;

            Text {
                text: root.is-save ? "Save list to file" : "Load list from file";
                font-weight: 600;
                color: black;
            }

            // Current directory bar + Up button
            HorizontalBox {
                spacing: 6px;

                IconButton {
                    icon: @image-url("assets/icons/up-arrow.png");
                    label: "Up";
                    height: 28px;
                    width: 60px;
                    clicked => {
                        root.navigate(root.current-dir + "/..");
                    }
                }
                LineEdit {
                    text: root.current-dir;
                    read-only: true;
                    horizontal-stretch: 1;
                    vertical-stretch: 0;
                    changed text => {
                        self.set-selection-offsets(self.text.character-count, self.text.character-count);
                    }
                }
            }

            // File and folder listing
            Rectangle {
                background: white;
                border-width: 1px;
                border-color: #aaaaaa;
                border-radius: 3px;
                height: 270px;

                ScrollView {
                    VerticalLayout {
                        spacing: 0px;
                        alignment: start;

                        for entry in root.entries: Rectangle {
                            height: 26px;
                            background: hov.has-hover ? #cde4fa : transparent;

                            hov := TouchArea {
                                clicked => {
                                    if (entry.is-dir) {
                                        root.navigate(root.current-dir + "/" + entry.name);
                                    } else {
                                        root.file-name = entry.name;
                                    }
                                }
                            }

                            HorizontalLayout {
                                padding-left: 8px;
                                padding-top: 4px;
                                padding-bottom: 4px;
                                spacing: 6px;
                                alignment: start;

                                Image {
                                    source: entry.is-dir ? @image-url("assets/icons/folder.png") : @image-url("assets/icons/document.png");
                                    width: 16px;
                                    height: 16px;
                                }

                                Text {
                                    text: entry.name;
                                    color: entry.is-dir ? #1a5fa8 : #222222;
                                    font-weight: entry.is-dir ? 600 : 400;
                                    vertical-alignment: center;
                                }
                            }
                        }
                    }
                }
            }

            // Filename input
            HorizontalBox {
                spacing: 8px;

                Text {
                    text: "File name:";
                    vertical-alignment: center;
                    min-width: 70px;
                }

                filename-input := LineEdit {
                    text <=> root.file-name;
                    placeholder-text: root.is-save ? "Enter filename…" : "Select a file above";
                    horizontal-stretch: 1;
                }
            }

            // Action buttons
            HorizontalBox {
                alignment: end;
                spacing: 8px;

                Button {
                    text: "Cancel";
                    clicked => { root.close(); }
                }

                Button {
                    text: root.is-save ? "Save" : "Load";
                    clicked => {
                        root.confirmed(root.current-dir + "/" + filename-input.text);
                        root.close();
                    }
                }
            }
        }
    }
}
