import { Button, ComboBox, HorizontalBox, LineEdit } from "std-widgets.slint";
import { KeyValuePair, LineItem, ActionType, Action } from "structs.slint";

export component LineCard inherits Rectangle {
    in property <LineItem> line;
    in property <[string]> schema-names;
    in property <int> line-index;

    callback dispatch(Action);

    border-width: 1px;
    border-color: #cccccc;
    border-radius: 4px;

    VerticalLayout {
        spacing: 4px;
        padding: 8px;

        // Line header: type selector + delete button
        HorizontalLayout {
            spacing: 8px;
            alignment: start;

            ComboBox {
                model: root.schema-names;
                current-value: root.line.title;
                selected(value) => {
                    root.dispatch({
                        action-type: ActionType.line-type-changed,
                        schema-name: value,
                        line-index: root.line-index,
                        pair-index: 0,
                        new-value: "",
                    });
                }
            }

            Button {
                text: "✕";
                clicked => {
                    root.dispatch({
                        action-type: ActionType.remove-line,
                        schema-name: "",
                        line-index: root.line-index,
                        pair-index: 0,
                        new-value: "",
                    });
                }
            }
        }

        for pair[j] in root.line.pairs: HorizontalBox {
            alignment: start;
            spacing: 8px;

            Text {
                text: pair.key + ":";
                min-width: 150px;
                vertical-alignment: center;
                color: black;
            }

            LineEdit {
                text: pair.value;
                min-width: 200px;
                edited(new-value) => {
                    root.dispatch({
                        action-type: ActionType.value-changed,
                        schema-name: "",
                        line-index: root.line-index,
                        pair-index: j,
                        new-value: new-value,
                    });
                }
            }

            if pair.unit-options.length > 0: ComboBox {
                model: pair.unit-options;
                current-value: pair.unit;
                selected(new-unit) => {
                    root.dispatch({
                        action-type: ActionType.unit-changed,
                        schema-name: "",
                        line-index: root.line-index,
                        pair-index: j,
                        new-value: new-unit,
                    });
                }
            }

            if pair.unit-options.length == 0 && pair.unit != "": Text {
                text: pair.unit;
                vertical-alignment: center;
                color: black;
            }
        }
    }
}
