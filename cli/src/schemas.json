      "label": {
        "ty": "Str"
      },
      "onClick": {
        "ty": "Str",
        "required": false
      },
      "disabled": {
        "ty": "Bool",
        "required": false
      }
    },
    "allow_unknown_keys": false
  },
  "TextField": {
    "values": {
      "placeholder": {
        "ty": "Str"
      },
      "maxLength": {
        "ty": "Int",
        "required": false
      },
      "value": {
        "ty": "Str",
        "required": false
      }
    },
    "allow_unknown_keys": false
  },
  "Container": {
    "values": {
      "width": {
        "ty": "Float",
        "required": false,
        "units": ["px", "em", "rem", "%"]
      },
      "height": {
        "ty": "Float",
        "required": false,
        "units": ["px", "em", "rem", "%"]
      },
      "padding": {
        "ty": "Int",
        "required": false,
        "units": "px"
      }
